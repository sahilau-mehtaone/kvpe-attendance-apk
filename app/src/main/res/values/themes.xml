<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Full-screen theme — no action bar, status bar matches brand color -->
    <style name="Theme.KvpeAttendance" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_blue</item>
        <item name="colorPrimaryVariant">@color/brand_blue_dark</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="android:windowBackground">@color/bg_white</item>
        <item name="android:statusBarColor">@color/brand_blue</item>
        <item name="android:navigationBarColor">@color/bg_white</item>
    </style>
</resources>
